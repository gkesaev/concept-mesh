# ─────────────────────────────────────────────────────────────
# ConceptMesh — local environment template
# Copy to .env.local and fill in the blanks.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# PostgreSQL 16 with pgvector. The docker-compose stack exposes
# it on localhost:5433 (to avoid clashing with a host Postgres).
DATABASE_URL=postgresql://concept:concept@localhost:5433/conceptmesh

# Credentials used by the docker-compose `db` service.
POSTGRES_USER=concept
POSTGRES_PASSWORD=concept
POSTGRES_DB=conceptmesh

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (NextAuth.js) ───────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# OAuth providers (optional — leave blank to disable)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 32-byte hex key used to encrypt user-supplied provider API keys at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Provider defaults (optional) ─────────────────────────────
# Server-side fallback when a user has not configured their own key.
# DEFAULT_PROVIDER selects which adapter to use: anthropic | openai | openai-compat
# DEFAULT_API_KEY is the plaintext key; it is encrypted in memory before use
# and is never sent to the client. Leave both blank to require per-user keys.
DEFAULT_PROVIDER=
DEFAULT_API_KEY=

# Legacy single-provider fallback — still honoured until the provider
# adapter layer (issue #11) lands. Prefer DEFAULT_PROVIDER/DEFAULT_API_KEY.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Card validation (Playwright) ─────────────────────────────
# Set to 1 to skip downloading browsers during `npm install` — useful in
# CI and Docker builds where browsers are provisioned in a dedicated step.
# Leave unset (or 0) for local dev so browsers install automatically.
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0
